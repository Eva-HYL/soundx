NODE_ENV=development
PORT=3000

# MySQL (Prisma)
DATABASE_URL=mysql://user:password@localhost:3306/soundx

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# WeChat Mini Program
WX_APP_ID=
WX_APP_SECRET=

# Object Storage (oss | s3 | local)
STORAGE_PROVIDER=local
STORAGE_ENDPOINT=
STORAGE_REGION=
STORAGE_BUCKET=soundx-dev
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_URL=http://localhost:3000/static

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:10086
